#!/usr/bin/env bash
# .githooks/pre-commit
#
# Block em-dash (U+2014) from being introduced via staged additions.
# Moonraker voice rule: replace with comma, period, colon, parenthesis,
# or restructure.
#
# Only checks ADDED lines in the staged diff, not the whole file. So
# legacy em-dashes already in a file do not block edits elsewhere in
# that file. New additions still get caught.
#
# Enabled via `core.hooksPath=.githooks` (set by `npm install` prepare
# script in JS repos, or `git config` for moonraker-agent).
# Bypass for a single commit: `git commit --no-verify`.

set -u

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

if [ -t 2 ]; then
  BOLD=$'\033[1m'; RED=$'\033[31m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  BOLD=""; RED=""; DIM=""; RESET=""
fi

EMDASH=$'\xe2\x80\x94'

hits=()
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    package-lock.json|yarn.lock|pnpm-lock.yaml|*.lock) continue ;;
    *.min.js|*.min.css|*.svg|*.po|*.mo|*.ico) continue ;;
    *.png|*.jpg|*.jpeg|*.gif|*.webp|*.avif|*.pdf) continue ;;
  esac
  if git diff --cached -U0 -- "$f" | grep -E '^\+[^+]' | grep -q -- "$EMDASH"; then
    hits+=("$f")
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "${#hits[@]}" -gt 0 ]; then
  printf '%s%spre-commit: em-dash (U+2014) found in staged additions:%s\n' "$BOLD" "$RED" "$RESET" >&2
  for f in "${hits[@]}"; do
    printf '  %s%s%s\n' "$BOLD" "$f" "$RESET" >&2
    git diff --cached -U0 -- "$f" | grep -E '^\+[^+]' | grep --color=always -- "$EMDASH" | head -5 | sed 's/^/    /' >&2
  done
  printf '\n%sFix: replace with comma, period, colon, parenthesis, or restructure.%s\n' "$DIM" "$RESET" >&2
  printf '%sBypass (discouraged): git commit --no-verify%s\n' "$DIM" "$RESET" >&2
  exit 1
fi

exit 0

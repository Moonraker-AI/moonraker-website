---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Book a call - Moonraker" description="Book a 30-minute call with Scott at Moonraker." canonical="https://moonraker.ai/book-a-call" ogTitle="Book a call - Moonraker" ogDescription="Pick a time that works and we will send a confirmation with the Zoom link." ogUrl="https://moonraker.ai/book-a-call">
<main>

<div class="contact-wrap">
  <div class="contact-header">
    <h1>Book a call</h1>
    <p>Pick a time that works and we'll send a confirmation with the Zoom link.</p>
  </div>

  <div class="tz-banner">
    <span class="tz-banner-icon">&#127758;</span>
    <div>
      <div><strong>You will be meeting with Scott, based in Western Australia (AWST).</strong> He takes new client calls Tuesday through Thursday mornings, 7:30 AM to 12 PM his local time. Pick whatever shows up in your own zone below.</div>
      <div class="tz-note">All times below are shown in your local zone (<span id="tzLabel">detecting...</span>).</div>
      <div class="tz-picker-row">Wrong zone? <select id="tzPicker" aria-label="Time zone"></select></div>
    </div>
  </div>
</div>

<div id="bookingWorkspace" class="booking-workspace">
  <div class="booking-card">

    <!-- Step 1: pick date -->
    <div class="booking-step" id="step1" data-active="true">
      <h2>Pick a day</h2>
      <p class="helper">Available days are when Scott has open time over the next three weeks.</p>
      <div id="dateStrip" class="date-strip">
        <div class="loading-state">Loading availability...</div>
      </div>
    </div>

    <!-- Step 2: pick time -->
    <div class="booking-step" id="step2" hidden>
      <button type="button" class="step-back" onclick="goToStep(1)">Back to dates</button>
      <h2 id="step2Title">Pick a time</h2>
      <p class="helper" id="step2Helper">Each call is 30 minutes. We will email you a confirmation with the Zoom link.</p>
      <div id="timeGrid" class="time-grid"></div>
    </div>

    <!-- Step 3: form (4 fields only) -->
    <div class="booking-step" id="step3" hidden>
      <button type="button" class="step-back" onclick="goToStep(2)">Back to times</button>
      <h2>A few details</h2>
      <p class="helper">Just a few details so we can send the calendar invite.</p>

      <div class="summary-box">
        <div class="summary-when" id="summaryWhen"></div>
        <div class="summary-sub" id="summarySub"></div>
      </div>

      <div class="form-grid">
        <div class="form-row">
          <label for="firstName">First name <span class="req">*</span></label>
          <input id="firstName" type="text" autocomplete="given-name" required>
          <div class="err">Please enter your first name.</div>
        </div>
        <div class="form-row">
          <label for="lastName">Last name <span class="req">*</span></label>
          <input id="lastName" type="text" autocomplete="family-name" required>
          <div class="err">Please enter your last name.</div>
        </div>
        <div class="form-row">
          <label for="email">Email <span class="req">*</span></label>
          <input id="email" type="email" autocomplete="email" required>
          <div class="err">Please enter a valid email address.</div>
        </div>
        <div class="form-row">
          <label for="practiceName">Practice or company name <span class="req">*</span></label>
          <input id="practiceName" type="text" autocomplete="organization" required>
          <div class="err">Please enter your practice or company name.</div>
        </div>
      </div>

      <div class="submit-row">
        <button type="button" class="btn btn-ghost" onclick="goToStep(2)">Back</button>
        <button type="button" class="btn btn-primary" id="submitBtn" onclick="submitBooking()">Book the call</button>
      </div>
      <div id="formError" class="error-state form-error-hidden"></div>
    </div>

    <!-- Step 4: confirmation -->
    <div class="booking-step confirm" id="step4" hidden>
      <div class="confirm-icon">&#10003;</div>
      <h2>You're booked.</h2>
      <p>A confirmation email is on its way with the Zoom link and a calendar invite. Scott will see you at your selected time.</p>
      <div class="confirm-details" id="confirmDetails"></div>
      <p class="confirm-note">Need to change anything? Reply to the confirmation email and we will sort it.</p>
    </div>

  </div>
</div>

</main>

<script is:inline>
(function () {
  'use strict';

  var API_ROOT = 'https://clients.moonraker.ai';

  var state = {
    tz: null,
    slots: [],
    daysIndex: {},
    selectedDate: null,
    selectedSlot: null,
    booking: null
  };

  function detectTz() {
    try { return Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC'; }
    catch (e) { return 'UTC'; }
  }

  function fmtTzAbbr(tz) {
    try {
      var parts = new Intl.DateTimeFormat('en-US', { timeZone: tz, timeZoneName: 'short' })
        .formatToParts(new Date());
      var n = parts.find(function (p) { return p.type === 'timeZoneName'; });
      return (n && n.value) || tz;
    } catch (e) { return tz; }
  }

  function fmtPerth(iso) {
    var d = new Date(iso);
    return new Intl.DateTimeFormat('en-US', {
      timeZone: 'Australia/Perth', hour: 'numeric', minute: '2-digit', hour12: true
    }).format(d);
  }

  function populateTzPicker(currentTz) {
    var common = [
      'America/New_York', 'America/Chicago', 'America/Denver', 'America/Los_Angeles',
      'America/Toronto', 'America/Vancouver',
      'Europe/London', 'Europe/Dublin', 'Europe/Paris', 'Europe/Berlin', 'Europe/Madrid',
      'Australia/Adelaide', 'Australia/Sydney', 'Australia/Perth', 'Australia/Brisbane',
      'Pacific/Auckland', 'Asia/Singapore', 'Africa/Johannesburg', 'UTC'
    ];
    if (common.indexOf(currentTz) === -1) common.unshift(currentTz);
    var sel = document.getElementById('tzPicker');
    common.forEach(function (tz) {
      var opt = document.createElement('option');
      opt.value = tz;
      opt.textContent = tz + ' (' + fmtTzAbbr(tz) + ')';
      if (tz === currentTz) opt.selected = true;
      sel.appendChild(opt);
    });
    sel.addEventListener('change', function (e) {
      state.tz = e.target.value;
      document.getElementById('tzLabel').textContent = state.tz + ', ' + fmtTzAbbr(state.tz);
      loadAvailability();
    });
  }

  function loadAvailability() {
    var dateStrip = document.getElementById('dateStrip');
    dateStrip.innerHTML = '<div class="loading-state">Loading availability...</div>';

    var fromDate = new Date();
    var toDate = new Date(fromDate.getTime() + 22 * 24 * 3600 * 1000);
    var fmtDate = function (d) {
      return d.getFullYear() + '-' +
        String(d.getMonth() + 1).padStart(2, '0') + '-' +
        String(d.getDate()).padStart(2, '0');
    };

    fetch(API_ROOT + '/api/booking/availability', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        from_date: fmtDate(fromDate),
        to_date: fmtDate(toDate),
        attendee_time_zone: state.tz
      })
    })
      .then(function (r) { return r.json().then(function (b) { return { ok: r.ok, body: b }; }); })
      .then(function (res) {
        if (!res.ok) {
          dateStrip.innerHTML = '<div class="error-state">' +
            (res.body && res.body.error ? res.body.error : 'Unable to load availability') +
            '</div>';
          return;
        }
        state.slots = res.body.slots || [];
        state.daysIndex = {};
        state.slots.forEach(function (s) {
          if (!state.daysIndex[s.attendee_date]) state.daysIndex[s.attendee_date] = [];
          state.daysIndex[s.attendee_date].push(s);
        });
        renderDates();
      })
      .catch(function () {
        dateStrip.innerHTML = '<div class="error-state">Unable to reach the booking service. Please refresh and try again.</div>';
      });
  }

  function renderDates() {
    var dateStrip = document.getElementById('dateStrip');
    var dates = Object.keys(state.daysIndex);
    if (dates.length === 0) {
      dateStrip.innerHTML = '<div class="empty-state">No openings in the next three weeks. Please email <a href="mailto:scott@moonraker.ai">scott@moonraker.ai</a> and we will find a time.</div>';
      return;
    }
    dates.sort(function (a, b) {
      return new Date(state.daysIndex[a][0].start_utc) -
        new Date(state.daysIndex[b][0].start_utc);
    });
    var html = '';
    dates.forEach(function (d) {
      var slot0 = state.daysIndex[d][0];
      var dateObj = new Date(slot0.start_utc);
      var weekday = new Intl.DateTimeFormat('en-US', { timeZone: state.tz, weekday: 'short' }).format(dateObj);
      var dayNum  = new Intl.DateTimeFormat('en-US', { timeZone: state.tz, day: 'numeric' }).format(dateObj);
      var month   = new Intl.DateTimeFormat('en-US', { timeZone: state.tz, month: 'short' }).format(dateObj);
      var count = state.daysIndex[d].length;
      html += '<button type="button" class="date-pill" data-date="' + d + '">' +
        '<div class="date-weekday">' + weekday + '</div>' +
        '<div class="date-day">' + dayNum + '</div>' +
        '<div class="date-month">' + month + '</div>' +
        '<div class="date-count">' + count + ' open</div>' +
        '</button>';
    });
    dateStrip.innerHTML = html;
    dateStrip.querySelectorAll('.date-pill').forEach(function (el) {
      el.addEventListener('click', function () {
        selectDate(el.getAttribute('data-date'));
      });
    });
  }

  function selectDate(dateStr) {
    state.selectedDate = dateStr;
    document.querySelectorAll('.date-pill').forEach(function (el) {
      el.classList.toggle('selected', el.getAttribute('data-date') === dateStr);
    });
    renderTimes();
    goToStep(2);
  }

  function renderTimes() {
    var slots = state.daysIndex[state.selectedDate] || [];
    var grid = document.getElementById('timeGrid');
    document.getElementById('step2Title').textContent =
      'Pick a time on ' + (slots[0] ? slots[0].attendee_date : '');
    if (slots.length === 0) {
      grid.innerHTML = '<div class="empty-state">No times available on this day.</div>';
      return;
    }
    var html = '';
    slots.forEach(function (s, i) {
      html += '<button type="button" class="time-pill" data-idx="' + i + '">' +
        '<div class="t-main">' + s.attendee_time + '</div>' +
        '<div class="t-sub">' + fmtPerth(s.start_utc) + ' Perth</div>' +
        '</button>';
    });
    grid.innerHTML = html;
    grid.querySelectorAll('.time-pill').forEach(function (el) {
      el.addEventListener('click', function () {
        var i = Number(el.getAttribute('data-idx'));
        selectSlot(slots[i]);
      });
    });
  }

  function selectSlot(slot) {
    state.selectedSlot = slot;
    populateSummary();
    goToStep(3);
  }

  function populateSummary() {
    var s = state.selectedSlot;
    if (!s) return;
    document.getElementById('summaryWhen').textContent =
      s.attendee_date + ' at ' + s.attendee_time + ' (' + s.attendee_tz_label + ')';
    document.getElementById('summarySub').textContent =
      'That is ' + fmtPerth(s.start_utc) + ' Perth time (Scott\'s zone). 30 minutes with Scott on Zoom.';
  }

  window.goToStep = function (n) {
    [1, 2, 3, 4].forEach(function (i) {
      var el = document.getElementById('step' + i);
      if (i === n) el.removeAttribute('hidden');
      else el.setAttribute('hidden', '');
    });
    window.scrollTo({ top: document.querySelector('.booking-workspace').offsetTop - 24, behavior: 'smooth' });
  };

  function setError(rowId, has) {
    document.getElementById(rowId).closest('.form-row').classList.toggle('has-error', has);
  }

  function validate() {
    var ok = true;
    var checks = [
      ['firstName',    function (v) { return v.trim().length > 0; }],
      ['lastName',     function (v) { return v.trim().length > 0; }],
      ['email',        function (v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()); }],
      ['practiceName', function (v) { return v.trim().length > 0; }]
    ];
    checks.forEach(function (c) {
      var el = document.getElementById(c[0]);
      var bad = !c[1](el.value);
      setError(c[0], bad);
      if (bad) ok = false;
    });
    return ok;
  }

  window.submitBooking = function () {
    if (!state.selectedSlot) return;
    if (!validate()) return;

    var btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Booking...';
    document.getElementById('formError').style.display = 'none';

    var payload = {
      first_name:         document.getElementById('firstName').value.trim(),
      last_name:          document.getElementById('lastName').value.trim(),
      email:              document.getElementById('email').value.trim(),
      practice_name:      document.getElementById('practiceName').value.trim(),
      attendee_time_zone: state.tz,
      start_at:           state.selectedSlot.start_utc,
      source:             'quick_book'
    };

    fetch(API_ROOT + '/api/booking/quick-book', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
      .then(function (r) { return r.json().then(function (b) { return { ok: r.ok, body: b, status: r.status }; }); })
      .then(function (res) {
        btn.disabled = false;
        btn.innerHTML = 'Book the call';
        if (!res.ok) {
          var msg = (res.body && res.body.error) || 'Booking failed. Please try again.';
          if (res.status === 409) {
            msg = 'That time was taken while you were filling in the form. Please pick another.';
            loadAvailability();
            goToStep(1);
          }
          document.getElementById('formError').textContent = msg;
          document.getElementById('formError').style.display = 'block';
          return;
        }
        state.booking = res.body;
        renderConfirmation(payload);
        goToStep(4);
      })
      .catch(function () {
        btn.disabled = false;
        btn.innerHTML = 'Book the call';
        document.getElementById('formError').textContent = 'Network error. Please try again.';
        document.getElementById('formError').style.display = 'block';
      });
  };

  function renderConfirmation(payload) {
    var s = state.selectedSlot;
    var html = '';
    html += '<div class="detail-row"><span class="detail-label">When</span>' +
      '<span class="detail-value">' + s.attendee_date + ' at ' + s.attendee_time + ' (' + s.attendee_tz_label + ')</span></div>';
    html += '<div class="detail-row"><span class="detail-label">Perth time</span>' +
      '<span class="detail-value">' + fmtPerth(s.start_utc) + '</span></div>';
    html += '<div class="detail-row"><span class="detail-label">Duration</span>' +
      '<span class="detail-value">30 minutes</span></div>';
    if (state.booking && state.booking.meeting_link) {
      html += '<div class="detail-row"><span class="detail-label">Zoom</span>' +
        '<span class="detail-value"><a href="' + state.booking.meeting_link + '" target="_blank" rel="noopener">Join link</a></span></div>';
    }
    html += '<div class="detail-row"><span class="detail-label">Confirmation sent to</span>' +
      '<span class="detail-value">' + payload.email + '</span></div>';
    document.getElementById('confirmDetails').innerHTML = html;
  }

  function startWorkspace() {
    state.tz = detectTz();
    document.getElementById('tzLabel').textContent = state.tz + ', ' + fmtTzAbbr(state.tz);
    populateTzPicker(state.tz);
    // Pre-fill email from ?email= query param (audit-email CTAs do this).
    try {
      var p = new URLSearchParams(window.location.search);
      var e = p.get('email');
      if (e) document.getElementById('email').value = e;
    } catch (ex) {}
    loadAvailability();
  }

  startWorkspace();
})();
</script>
</BaseLayout>
<style>
/* Page-specific styles. Tokens come from /styles/globals.css. */

.contact-wrap {
  position: relative; overflow: hidden;
  background: linear-gradient(180deg, var(--color-primary-subtle) 0%, var(--color-bg) 62%);
  border-bottom: 1px solid var(--color-hairline);
  padding: 3rem 2rem 2rem;
}
.contact-wrap::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, oklch(0.31 0.072 268 / 0.045) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.31 0.072 268 / 0.045) 1px, transparent 1px);
  background-size: 62px 62px;
  -webkit-mask-image: radial-gradient(70% 90% at 50% 0%, #000 0%, transparent 78%);
  mask-image: radial-gradient(70% 90% at 50% 0%, #000 0%, transparent 78%);
  pointer-events: none;
}
html.dark .contact-wrap::before {
  background-image:
    linear-gradient(to right, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px);
}
.contact-wrap > * { position: relative; z-index: 1; }
.contact-header { max-width: 720px; margin: 0 auto; text-align: center; }
.contact-header h1 {
  font-family: 'Outfit', sans-serif; font-weight: 800;
  font-size: 2.5rem; line-height: 1.15; color: var(--color-heading);
  margin-bottom: 1rem; letter-spacing: -.01em;
}
.contact-header p {
  font-size: 1rem; color: var(--color-muted);
  line-height: 1.65; margin-bottom: 1.5rem;
}

/* TZ banner */
.tz-banner {
  max-width: 720px; margin: 1rem auto 0;
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: 12px; padding: 1rem 1.25rem;
  display: flex; gap: 1rem; align-items: center;
  font-size: .85rem; color: var(--color-body); line-height: 1.5;
  text-align: left;
}
.tz-banner-icon { font-size: 1.25rem; flex-shrink: 0; }
.tz-banner strong { color: var(--color-heading); font-weight: 600; }
.tz-note { margin-top: .35rem; color: var(--color-muted); }
.tz-picker-row { margin-top: .35rem; }
.tz-banner select {
  margin-top: .35rem; font-family: inherit; font-size: .82rem;
  padding: .3rem .5rem; border: 1px solid var(--color-border);
  border-radius: 6px; background: var(--color-bg); color: var(--color-body);
}
.tz-banner select:focus { outline: none; border-color: var(--color-primary); }

/* Booking workspace */
.booking-workspace {
  max-width: 1080px; margin: 2.5rem auto 4rem;
  padding: 0 2rem;
}
.booking-card {
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--r-lg); box-shadow: var(--shadow-card);
  overflow: hidden;
}
.booking-step { padding: 2rem; }
.booking-step h2 {
  font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.25rem;
  color: var(--color-heading); margin-bottom: 1.25rem;
}
.booking-step p.helper {
  color: var(--color-muted); font-size: .85rem;
  margin: -.75rem 0 1.5rem; line-height: 1.6;
}
.step-back {
  display: inline-flex; align-items: center; gap: .35rem;
  background: none; border: none; cursor: pointer; padding: .25rem .5rem;
  margin-bottom: 1rem; font-family: inherit; font-size: .82rem;
  color: var(--color-muted); border-radius: 6px;
}
.step-back:hover { color: var(--color-primary); background: var(--color-primary-subtle); }
.step-back::before { content: '\2190'; }

/* Date pills */
.date-strip {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(108px, 1fr));
  gap: .65rem;
}
.date-pill {
  background: var(--color-bg); border: 1px solid var(--color-border);
  border-radius: 12px; padding: .85rem .5rem; cursor: pointer;
  text-align: center; transition: border-color .15s, transform .12s;
}
.date-pill:hover {
  border-color: var(--color-primary); transform: translateY(-1px);
}
.date-pill.selected {
  background: var(--color-primary); border-color: var(--color-primary); color: #fff;
}
.date-pill .date-weekday {
  font-size: .7rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: .04em; color: var(--color-muted); margin-bottom: .35rem;
}
.date-pill.selected .date-weekday { color: rgba(255,255,255,.85); }
.date-pill .date-day {
  font-family: 'Outfit', sans-serif; font-weight: 700;
  font-size: 1.5rem; color: var(--color-heading); line-height: 1;
}
.date-pill.selected .date-day { color: #fff; }
.date-pill .date-month {
  font-size: .7rem; color: var(--color-muted); margin-top: .25rem;
}
.date-pill.selected .date-month { color: rgba(255,255,255,.8); }
.date-pill .date-count {
  font-size: .65rem; color: var(--color-primary); margin-top: .25rem;
  font-weight: 600;
}
.date-pill.selected .date-count { color: rgba(255,255,255,.85); }

/* Time slots */
.time-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: .65rem;
}
.time-pill {
  background: var(--color-bg); border: 1px solid var(--color-border);
  border-radius: 10px; padding: .75rem; cursor: pointer; text-align: center;
  transition: border-color .15s, transform .12s, background .15s;
  font-family: inherit;
}
.time-pill:hover { border-color: var(--color-primary); transform: translateY(-1px); }
.time-pill.selected { background: var(--color-primary); border-color: var(--color-primary); color: #fff; }
.time-pill .t-main { font-weight: 600; font-size: .92rem; color: var(--color-heading); }
.time-pill.selected .t-main { color: #fff; }
.time-pill .t-sub {
  font-size: .68rem; color: var(--color-muted); margin-top: 2px;
}
.time-pill.selected .t-sub { color: rgba(255,255,255,.8); }

/* Form */
.form-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem 1.25rem;
}
.form-row { display: flex; flex-direction: column; }
.form-row.full { grid-column: 1 / -1; }
.form-row label {
  font-size: .78rem; font-weight: 600;
  color: var(--color-heading); margin-bottom: .35rem;
}
.form-row label .req { color: var(--color-primary); }
.form-row input, .form-row select, .form-row textarea {
  width: 100%; padding: .65rem .85rem; border: 1px solid var(--color-border);
  border-radius: 8px; font-family: inherit; font-size: .9rem;
  background: var(--color-bg); color: var(--color-body);
  transition: border-color .15s, box-shadow .15s;
}
.form-row textarea { resize: vertical; min-height: 80px; }
.form-row input:focus, .form-row select:focus, .form-row textarea:focus {
  outline: none; border-color: var(--color-primary);
  box-shadow: 0 0 0 3px oklch(0.74 0.165 162 / .1);
}
.form-row .helper-text {
  font-size: .72rem; color: var(--color-muted); margin-top: .35rem; line-height: 1.5;
}
.form-row .err { color: var(--color-danger); font-size: .72rem; margin-top: .35rem; display: none; }
.form-row.has-error input,
.form-row.has-error select,
.form-row.has-error textarea { border-color: var(--color-danger); }
.form-row.has-error .err { display: block; }

.summary-box {
  background: var(--color-primary-subtle); border: 1px solid oklch(0.74 0.165 162 / .25);
  border-radius: var(--r-md); padding: 1rem 1.25rem; margin-bottom: 1.5rem;
}
.summary-box .summary-when {
  font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 1.05rem;
  color: var(--color-heading); margin-bottom: .25rem;
}

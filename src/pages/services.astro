---
import BaseLayout from '../layouts/BaseLayout.astro';

const SERVICES_LD = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Moonraker starting steps",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "item": {
        "@type": "Service",
        "name": "Visibility Audit + Fixes",
        "serviceType": "Website and visibility audit with remediation",
        "provider": { "@type": "Organization", "name": "Moonraker AI", "url": "https://moonraker.ai" },
        "description": "A full review of how a therapy practice shows up on Google, Maps, and AI tools, with the fixes applied on the practice's current website platform."
      }
    },
    {
      "@type": "ListItem",
      "position": 2,
      "item": {
        "@type": "Service",
        "name": "Platform Upgrade",
        "serviceType": "Website platform migration",
        "provider": { "@type": "Organization", "name": "Moonraker AI", "url": "https://moonraker.ai" },
        "description": "The audit and fixes, plus a page-for-page move of the existing website onto Moonraker's fast, secure Cloudflare foundation with a rebuilt data layer and tuned internal links."
      }
    },
    {
      "@type": "ListItem",
      "position": 3,
      "item": {
        "@type": "Service",
        "name": "Full Practice Rebuild",
        "serviceType": "Website redesign and conversion page buildout",
        "provider": { "@type": "Organization", "name": "Moonraker AI", "url": "https://moonraker.ai" },
        "description": "The platform move, plus a full redesign and the missing pages: services, modalities, locations, team bios, and conversion-focused landing pages."
      }
    }
  ]
});
---
<BaseLayout
  title="Services | Three Clear Starting Steps | Moonraker"
  description="Three ways to start with Moonraker: a visibility audit with fixes on your current site, a page-for-page move onto our Cloudflare foundation, or a full redesign with the pages your practice is missing."
  canonical="https://moonraker.ai/services"
  ogTitle="Moonraker Services"
  ogDescription="Start where you are: audit and fixes, a platform upgrade, or a full practice rebuild."
  ogUrl="https://moonraker.ai/services"
>
<script slot="head" type="application/ld+json" is:inline set:html={SERVICES_LD}></script>
<main>
  <section class="services-hero">
    <div class="hero-inner">
      <div>
        <div class="hero-kicker">Services</div>
        <h1>Start where you are. <span style="color: var(--color-primary)">Build from there.</span></h1>
        <p>Every practice comes to us in a different place. Some need a clear list of what to fix. Some need a faster, more stable website. Some are ready for a complete rebuild. We shaped the work into three steps so you can begin at the level that fits, and each step builds on the one before it.</p>
      </div>
      <aside class="ladder-stack" aria-label="The three starting steps">
        <h2 class="sr-only">The three starting steps</h2>
        <div class="ladder-preview"><div class="ladder-num">1</div><div><h3>Visibility Audit + Fixes</h3><p>Find every gap, then fix what we can on your current website.</p></div></div>
        <div class="ladder-preview"><div class="ladder-num">2</div><div><h3>Platform Upgrade</h3><p>Everything above, plus your site moved page for page onto our Cloudflare foundation.</p></div></div>
        <div class="ladder-preview"><div class="ladder-num">3</div><div><h3>Full Practice Rebuild</h3><p>Everything above, plus a full redesign and the pages your practice is missing.</p></div></div>
      </aside>
    </div>
  </section>

  <section class="section-wrap">
    <div class="section-head">
      <div><div class="section-label">The ladder</div><h2>Three steps. Each one includes the last.</h2></div>
      <p>You do not have to guess which step is right. The free strategy call shows you where your practice stands, and we recommend the smallest step that actually solves the problem. We do not publish pricing here because every proposal is scoped on the call, but every step is a flat-rate project with a clear deliverable list.</p>
    </div>

    <div class="tier-list">
      <article class="tier-card">
        <div class="tier-head">
          <div class="tier-num">1</div>
          <div>
            <div class="tier-tag">Know exactly what is broken</div>
            <h3>Visibility Audit + Fixes</h3>
            <p class="tier-lede">A complete review of how your practice shows up on Google, Maps, and AI tools, followed by the fixes, applied right on your current website. Nothing moves. Your site stays on the platform it is on today.</p>
          </div>
        </div>
        <div class="tier-body">
          <div>
            <h4>What you get</h4>
            <ul>
              <li>A full audit across your website, Google Business Profile, local listings, service pages, and booking path.</li>
              <li>On-page fixes on your existing platform: titles, descriptions, structured data, indexing issues, and broken links.</li>
              <li>Cleanup of the practice details Google and AI tools check for consistency.</li>
              <li>A written report of everything we fixed and everything that still needs attention, in plain language.</li>
            </ul>
          </div>
          <div class="tier-note">
            <h4>Best for</h4>
            <p>Practices that like their current website and want it to work harder, or that want a clear, honest starting point before committing to bigger changes.</p>
          </div>
        </div>
      </article>

      <article class="tier-card">
        <div class="tier-head">
          <div class="tier-num">2</div>
          <div>
            <div class="tier-tag">Move to stronger ground</div>
            <h3>Platform Upgrade</h3>
            <p class="tier-lede">Everything in the audit step, plus we move your website, page for page, onto our fast and secure Cloudflare foundation. Same pages, same content, same structure. What changes is everything underneath.</p>
          </div>
        </div>
        <div class="tier-body">
          <div>
            <h4>What you get</h4>
            <ul>
              <li>Everything in Visibility Audit + Fixes.</li>
              <li>Your existing site rebuilt page for page on our Cloudflare foundation: fast to load, stable, and secure.</li>
              <li>A rebuilt data layer on every page, so Google and AI tools can actually read what your practice offers.</li>
              <li>On-page technicals and internal links tuned across the whole site.</li>
            </ul>
          </div>
          <div class="tier-note boundary">
            <h4>What this step does not include</h4>
            <p>New pages. If the audit shows your site is missing service, location, or bio pages, we document exactly what is missing and why it matters, but building new pages is Full Practice Rebuild work.</p>
          </div>
        </div>
      </article>

      <article class="tier-card featured">
        <div class="tier-head">
          <div class="tier-num">3</div>
          <div>
            <div class="tier-tag">The complete foundation</div>
            <h3>Full Practice Rebuild</h3>
            <p class="tier-lede">Everything in the platform upgrade, plus a full redesign and the pages your practice has been missing. This is the step where the website stops describing your practice and starts booking for it.</p>
          </div>
        </div>
        <div class="tier-body">
          <div>
            <h4>What you get</h4>
            <ul>
              <li>Everything in Platform Upgrade.</li>
              <li>A fresh design built around your practice: branding, color, and typography that feel like you.</li>
              <li>Content gaps filled: clear pages for your services, modalities, locations, and team bios.</li>
              <li>Conversion-focused landing pages built for the searches people run right before they book a consultation.</li>
              <li>A booking path that is obvious from every page.</li>
            </ul>
          </div>
          <div class="tier-note">
            <h4>Best for</h4>
            <p>Practices ready to treat the website as their strongest referral source, not just a brochure. This is the foundation the ongoing CORE work compounds on fastest.</p>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="core-band">
    <div class="section-wrap">
      <div class="section-head">
        <div><div class="section-label">After the foundation</div><h2>Every step feeds the same system.</h2></div>
        <p>Whichever step you start with, the work rolls into our <a href="/core-marketing-system">CORE Marketing System</a>: public proof, reporting, and recommendations that keep your visibility compounding month over month. The foundation step decides how fast that compounding starts, not whether it happens. See <a href="/process">how the first 90 days work</a>.</p>
      </div>
    </div>
  </section>

  <section class="faq-band">
    <div class="section-wrap">
      <div class="section-label">FAQ</div>
      <h2>Questions practices ask about the steps.</h2>
      <div class="faq-list faq-list-spaced">
        <details open name="services-faq"><summary>Which step is right for us?</summary><p>The free strategy call answers this. We review your visibility and recommend the smallest step that solves what we find. Plenty of practices start with the audit and move up later.</p></details>
        <details name="services-faq"><summary>Do we have to move our website?</summary><p>No. Visibility Audit + Fixes works entirely on your current platform. We only recommend the platform move when your current hosting or builder is holding the site back.</p></details>
        <details name="services-faq"><summary>If you move our site, will it look different?</summary><p>No. The Platform Upgrade is page for page: same pages, same content, same structure. Design changes and new pages happen only in the Full Practice Rebuild.</p></details>
        <details name="services-faq"><summary>How does pricing work?</summary><p>Each step is a flat-rate project, scoped and quoted in a written proposal after the strategy call. No hourly billing and no surprises mid-project.</p></details>
        <details name="services-faq"><summary>What happens after the foundation step?</summary><p>Most practices continue into ongoing CORE support, where we keep improving your public proof, reporting, and visibility signals. The foundation step stands on its own either way: you own everything we build.</p></details>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="cta-inner">
      <div><h2>Not sure which step fits?</h2><p>Book a free strategy call. We will show you where your practice stands and which starting step actually makes sense.</p></div>
      <a class="btn btn-primary" href="/free-strategy-call">Book a Free Strategy Call</a>
    </div>
  </section>
</main>
</BaseLayout>

<style>
.services-hero { position: relative; overflow: hidden; background: linear-gradient(158deg, var(--color-navy) 0%, var(--color-navy-deep) 100%); color: var(--color-on-navy-dim); padding: clamp(3.5rem, 7vw, 5rem) 2rem clamp(2.75rem, 5vw, 3.5rem); }
.services-hero::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px);
  background-size: 62px 62px;
  -webkit-mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  pointer-events: none;
}
.services-hero .hero-inner { position: relative; z-index: 1; }
.hero-inner { max-width: 1120px; margin: 0 auto; display: grid; grid-template-columns: 1fr .95fr; gap: clamp(2rem, 6vw, 4rem); align-items: center; }
.hero-kicker { color: var(--color-primary); font-weight: 800; font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .8rem; }
.services-hero h1 { color: var(--color-on-navy); font-size: clamp(2.5rem, 5vw, 4.7rem); line-height: 1.03; letter-spacing: -.02em; margin-bottom: 1.1rem; }
.services-hero p { color: var(--color-on-navy-dim); font-size: 1.08rem; line-height: 1.75; }
.ladder-stack { border: 1px solid var(--color-hairline); border-radius: var(--r-lg); overflow: hidden; background: var(--color-surface); box-shadow: var(--shadow-card); }
.ladder-preview { display: grid; grid-template-columns: 64px 1fr; gap: 1rem; padding: 1.1rem; border-bottom: 1px solid var(--color-border); }
.ladder-preview:last-child { border-bottom: 0; }
.ladder-num { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; background: var(--color-navy); color: var(--color-primary); font-family: 'Outfit', sans-serif; font-size: 1.35rem; font-weight: 800; }
.ladder-preview h3 { margin-bottom: .25rem; }
.ladder-preview p { font-size: .84rem; line-height: 1.55; color: var(--color-muted); }
.section-wrap { max-width: 1120px; margin: 0 auto; padding: clamp(4rem, 7vw, 6rem) 2rem; }
.section-label { color: var(--color-primary); font-weight: 800; font-size: .74rem; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .7rem; }
.section-head { display: grid; grid-template-columns: .9fr 1.1fr; gap: 2rem; margin-bottom: 2rem; align-items: end; }
.section-head h2 { font-size: clamp(2rem, 3.6vw, 3rem); }
.section-head p { color: var(--color-muted); line-height: 1.75; }
.section-head a { color: var(--color-primary); font-weight: 600; }
.tier-list { display: grid; gap: 1.25rem; }
.tier-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--r-lg); padding: clamp(1.5rem, 3vw, 2.25rem); }
.tier-card.featured { background: linear-gradient(158deg, var(--color-navy) 0%, var(--color-navy-deep) 100%); border-color: transparent; color: var(--color-on-navy-dim); }
.tier-card.featured h3, .tier-card.featured h4 { color: var(--color-on-navy); }
.tier-card.featured .tier-lede, .tier-card.featured li, .tier-card.featured .tier-note p { color: var(--color-on-navy-dim); }
.tier-head { display: grid; grid-template-columns: 64px 1fr; gap: 1.25rem; align-items: start; margin-bottom: 1.4rem; }
.tier-num { width: 52px; height: 52px; border-radius: 14px; display: grid; place-items: center; background: var(--color-navy); color: var(--color-primary); font-family: 'Outfit', sans-serif; font-size: 1.35rem; font-weight: 800; }
.tier-card.featured .tier-num { background: var(--color-primary); color: var(--color-navy); }
.tier-tag { color: var(--color-primary); font-weight: 800; font-size: .74rem; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .4rem; }
.tier-card h3 { font-size: clamp(1.4rem, 2.4vw, 1.9rem); margin-bottom: .55rem; }
.tier-lede { color: var(--color-muted); line-height: 1.7; max-width: 68ch; }
.tier-body { display: grid; grid-template-columns: 1.25fr .75fr; gap: 1.5rem; }
.tier-body h4 { font-size: .82rem; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .7rem; }
.tier-body ul { list-style: none; display: grid; gap: .55rem; }
.tier-body li { color: var(--color-body); font-size: .93rem; line-height: 1.6; padding-left: 1.15rem; position: relative; }
.tier-body li::before { content: ''; position: absolute; left: 0; top: .6em; width: 7px; height: 7px; border-radius: 50%; background: var(--color-primary); }
.tier-note { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--r-md); padding: 1.1rem 1.25rem; align-self: start; }
.tier-card.featured .tier-note { background: oklch(1 0 0 / 0.06); border-color: oklch(1 0 0 / 0.12); }
.tier-note p { color: var(--color-muted); font-size: .9rem; line-height: 1.65; }
.tier-note.boundary h4 { color: var(--color-danger); }
.core-band { background: var(--color-surface); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
.core-band .section-head { margin-bottom: 0; }
.core-band a { color: var(--color-primary); font-weight: 600; }
.faq-band { background: var(--color-bg); }
.faq-list { display: grid; gap: .8rem; }
.faq-list-spaced { margin-top: 2rem; }
details { background: var(--color-surface); border: 1px solid var(--color-hairline); border-radius: var(--r-md); padding: 1.1rem 1.25rem; }
summary { cursor: pointer; font-family: 'Outfit', sans-serif; color: var(--color-heading); font-weight: 800; }
details p { color: var(--color-muted); font-size: .92rem; line-height: 1.7; margin-top: .8rem; }
.cta-band { position: relative; overflow: hidden; background: linear-gradient(158deg, var(--color-navy) 0%, var(--color-navy-deep) 100%); color: var(--color-on-navy-dim); }
.cta-band::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px);
  background-size: 58px 58px;
  -webkit-mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  pointer-events: none;
}
.cta-inner { position: relative; z-index: 1; max-width: 1120px; margin: 0 auto; padding: clamp(3rem, 6vw, 4rem) 2rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center; }
.cta-inner h2 { color: var(--color-on-navy); margin-bottom: .6rem; }
.cta-inner p { color: var(--color-on-navy-dim); }
@media (max-width: 860px) {
  .hero-inner, .section-head, .tier-body, .cta-inner { grid-template-columns: 1fr; }
  .tier-head { grid-template-columns: 1fr; }
  .tier-num { margin-bottom: .25rem; }
}
</style>

---
<BaseLayout title="Meet the Team | Moonraker" description="The specialists behind Moonraker: the people who build your search presence, write the strategy, and help your therapy practice grow online." canonical="https://moonraker.ai/team" ogTitle="Meet the Moonraker Team" ogDescription="Real specialists, not a faceless agency. Meet the people who build your search presence and grow your practice." ogUrl="https://moonraker.ai/team">
<main>
  <section class="team-hero">
    <div class="hero-inner">
      <div class="hero-kicker">The people behind Moonraker</div>
      <h1>Meet the team behind your <span style="color: var(--color-primary)">visibility.</span></h1>
      <p>Real specialists, not a faceless agency. These are the people who build your search presence, write the strategy, and stay close to your practice as it grows.</p>
    </div>
  </section>

  <section class="team-section">
    {groups.map((group) => (
      <div class="team-group">
        <header class="team-cat"><h2 class="team-cat-title">{group.title}</h2></header>
        <div class={`team-row ${group.layout === 'three' ? 'three' : ''}`}>
          {group.members.map((m) => (
            <article class="team-card">
              <div class="team-photo">
                <picture>
                  <source srcset={m.avif} type="image/avif" />
                  <img src={m.img} alt={m.alt} width={m.width} height={m.height} loading={m.loading} />
                </picture>
              </div>
              <div class="team-body">
                <div class="team-role">{m.role}</div>
                <h2 class="team-name">{m.name}</h2>
                <button class="team-learn" type="button" data-bio-open={`bio-${m.slug}`} aria-haspopup="dialog" aria-label={`Learn more about ${m.name}`}>
                  Learn more
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </button>
              </div>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>

  <section class="cta-band">
    <div class="cta-inner">
      <div><h2>Want to put this team to work?</h2><p>Start with a free strategy call. We will look at where your practice stands and whether we are the right fit.</p></div>
      <a class="btn btn-primary" href="/free-strategy-call">Book a Free Strategy Call</a>
    </div>
  </section>

  {groups.flatMap((group) => group.members).map((m) => (
    <dialog class="bio-modal" id={`bio-${m.slug}`} aria-labelledby={`bio-${m.slug}-name`}>
      <div class="bio-modal-inner">
        <button class="bio-close" type="button" data-bio-close aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <div class="bio-modal-grid">
          <div class="bio-modal-photo">
            <picture>
              <source srcset={m.avif} type="image/avif" />
              <img src={m.img} alt={m.alt} width={m.width} height={m.height} loading="lazy" />
            </picture>
          </div>
          <div class="bio-modal-text">
            <div class="team-role">{m.role}</div>
            <h2 id={`bio-${m.slug}-name`} class="bio-modal-name">{m.name}</h2>
            <p class="bio-modal-bio">{m.bio}</p>
            <a class="team-linkedin" href={m.linkedin} target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={LINKEDIN_PATH}/></svg>
              Connect on LinkedIn
            </a>
          </div>
        </div>
      </div>
    </dialog>
  ))}
</main>
</BaseLayout>
<style>
.team-hero { position: relative; overflow: hidden; background: linear-gradient(158deg, var(--color-navy) 0%, var(--color-navy-deep) 100%); color: var(--color-on-navy-dim); padding: clamp(3.5rem, 7vw, 5rem) 2rem clamp(2.75rem, 5vw, 3.5rem); }
.team-hero::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px);
  background-size: 62px 62px;
  -webkit-mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  pointer-events: none;
}
.team-hero .hero-inner { position: relative; z-index: 1; max-width: 760px; margin: 0 auto; text-align: center; }
.team-hero .hero-kicker { color: var(--color-primary); font-weight: 800; font-size: .78rem; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .8rem; }
.team-hero h1 { color: var(--color-on-navy); font-size: clamp(2.5rem, 5vw, 4.7rem); line-height: 1.03; letter-spacing: -.02em; margin-bottom: 1.1rem; }
.team-hero p { color: var(--color-on-navy-dim); font-size: 1.08rem; line-height: 1.75; max-width: 600px; margin: 0 auto; }

.team-section { max-width: 1180px; margin: 0 auto; padding: clamp(3.5rem, 6vw, 5.5rem) 2rem clamp(4rem, 7vw, 6rem); }
.team-group + .team-group { margin-top: clamp(3rem, 6vw, 5rem); }
.team-cat { text-align: center; margin-bottom: clamp(1.75rem, 3vw, 2.5rem); }
.team-cat-title { font-family: 'Outfit', sans-serif; font-size: clamp(1.7rem, 2.8vw, 2.3rem); font-weight: 800; color: var(--color-heading); letter-spacing: -.01em; }
.team-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(16.5rem, 21rem)); gap: clamp(1.25rem, 2.5vw, 2rem); justify-content: center; }
.team-row.three { grid-template-columns: repeat(3, minmax(0, 21rem)); }
@media (max-width: 880px) { .team-row.three { grid-template-columns: repeat(2, minmax(0, 21rem)); } }
@media (max-width: 600px) { .team-row, .team-row.three { grid-template-columns: minmax(0, 21rem); } }
.team-card {
  background: var(--color-surface);
  border: 1px solid var(--color-hairline);
  border-radius: var(--r-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .25s ease, box-shadow .25s ease;
}
.team-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
.team-photo { aspect-ratio: 4 / 5; overflow: hidden; background: var(--color-primary-subtle); }
.team-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 20%; display: block; }
.team-body { padding: clamp(1.3rem, 2vw, 1.7rem); display: flex; flex-direction: column; flex: 1; }
.team-role { color: var(--color-primary); font-weight: 800; font-size: .72rem; text-transform: uppercase; letter-spacing: .06em; }
.team-name { font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 800; color: var(--color-heading); line-height: 1.15; margin: .35rem 0 1rem; }
.team-learn {
  margin-top: auto; align-self: flex-start; display: inline-flex; align-items: center; gap: .5rem;
  background: var(--color-primary-subtle); color: var(--color-primary);
  border: 1px solid color-mix(in oklab, var(--color-primary) 22%, transparent);
  border-radius: var(--r-md, 10px); padding: .6rem 1.05rem;
  font-family: inherit; font-weight: 700; font-size: .9rem; cursor: pointer;
  transition: background .2s ease, transform .2s ease, box-shadow .2s ease;
}
.team-learn svg { width: 16px; height: 16px; flex: none; transition: transform .2s ease; }
.team-learn:hover { background: var(--color-primary); color: #fff; }
.team-learn:hover svg { transform: translateX(3px); }
.team-learn:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.team-linkedin { margin-top: auto; padding-top: 1.1rem; display: inline-flex; align-items: center; gap: .45rem; color: var(--color-primary); font-weight: 600; font-size: .85rem; text-decoration: none; align-self: flex-start; }
.team-linkedin svg { width: 17px; height: 17px; flex: none; }
.team-linkedin:hover { text-decoration: underline; }

/* Bio modal: native dialog, two-column on desktop (larger photo + scrollable bio). */
.bio-modal {
  width: min(880px, calc(100vw - 2rem)); max-height: min(90vh, 720px);
  padding: 0; border: 0; border-radius: var(--r-xl, 20px); overflow: hidden;
  background: var(--color-surface); color: var(--color-body);
  box-shadow: 0 30px 80px -20px rgba(7, 18, 33, .55);
}
.bio-modal::backdrop { background: rgba(7, 18, 33, .62); backdrop-filter: blur(3px); }
.bio-modal[open] { animation: bio-pop .28s cubic-bezier(.16, 1, .3, 1); }
@keyframes bio-pop { from { opacity: 0; transform: translateY(12px) scale(.98); } to { opacity: 1; transform: none; } }
@media (prefers-reduced-motion: reduce) { .bio-modal[open] { animation: none; } }
.bio-modal-inner { position: relative; max-height: inherit; }
.bio-close {
  position: absolute; top: .85rem; right: .85rem; z-index: 2;
  width: 2.3rem; height: 2.3rem; display: grid; place-items: center;
  border: 0; border-radius: 999px; cursor: pointer;
  background: rgba(255, 255, 255, .82); color: var(--color-navy, #0b1b2d);
  box-shadow: 0 2px 10px rgba(7, 18, 33, .2); transition: background .2s ease, transform .2s ease;
}
.bio-close svg { width: 18px; height: 18px; }
.bio-close:hover { background: #fff; transform: rotate(90deg); }
.bio-close:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 2px; }
.bio-modal-grid { display: grid; grid-template-columns: minmax(0, 320px) 1fr; max-height: inherit; }
.bio-modal-photo { background: var(--color-primary-subtle); overflow: hidden; }
.bio-modal-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 18%; display: block; }
.bio-modal-text { padding: clamp(1.75rem, 3vw, 2.5rem); overflow-y: auto; }
.bio-modal-name { font-family: 'Outfit', sans-serif; font-size: clamp(1.6rem, 3vw, 2.1rem); font-weight: 800; color: var(--color-heading); line-height: 1.12; margin: .4rem 0 1rem; }
.bio-modal-bio { color: var(--color-body); font-size: 1rem; line-height: 1.75; }
.bio-modal-text .team-linkedin { margin-top: 1.5rem; padding-top: 0; }
@media (max-width: 680px) {
  .bio-modal { max-height: 92vh; }
  .bio-modal-grid { grid-template-columns: 1fr; grid-template-rows: auto 1fr; overflow-y: auto; }
  .bio-modal-photo { aspect-ratio: 4 / 3; }
}

.cta-band { position: relative; overflow: hidden; background: linear-gradient(158deg, var(--color-navy) 0%, var(--color-navy-deep) 100%); color: var(--color-on-navy-dim); }
.cta-band::before {
  content: ''; position: absolute; inset: 0;
  background-image:
    linear-gradient(to right, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px),
    linear-gradient(to bottom, oklch(0.945 0.018 166 / 0.05) 1px, transparent 1px);
  background-size: 58px 58px;
  -webkit-mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  mask-image: radial-gradient(80% 120% at 50% 0%, #000 0%, transparent 72%);
  pointer-events: none;
}
.cta-inner { position: relative; z-index: 1; max-width: 1120px; margin: 0 auto; padding: clamp(3rem, 6vw, 4rem) 2rem; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center; }
.cta-inner h2 { color: var(--color-on-navy); margin-bottom: .6rem; }
.cta-inner p { color: var(--color-on-navy-dim); }
@media (max-width: 860px) {
  .cta-inner { grid-template-columns: 1fr; }
}
</style>

<script is:inline>
  // Bio modals: open the matching <dialog>, lock body scroll, restore focus on
  // close. Backdrop click and the close button both dismiss; ESC is native.
  (() => {
    let lastTrigger = null;
    function open(id, trigger) {
      const dialog = document.getElementById(id);
      if (!dialog || typeof dialog.showModal !== 'function') return;
      lastTrigger = trigger || null;
      dialog.showModal();
      document.body.style.overflow = 'hidden';
    }
    function close(dialog) {
      if (!dialog || !dialog.open) return;
      dialog.close();
    }
    document.addEventListener('click', (e) => {
      const opener = e.target.closest('[data-bio-open]');
      if (opener) { open(opener.getAttribute('data-bio-open'), opener); return; }
      const closer = e.target.closest('[data-bio-close]');
      if (closer) { close(closer.closest('dialog')); return; }
      // Click on the dialog element itself (its backdrop area) closes it.
      if (e.target.tagName === 'DIALOG') close(e.target);
    });
    document.querySelectorAll('dialog.bio-modal').forEach((dialog) => {
      dialog.addEventListener('close', () => {
        document.body.style.overflow = '';
        if (lastTrigger) { lastTrigger.focus(); lastTrigger = null; }
      });
    });
  })();
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';

// LinkedIn glyph path, shared by the card-less modal and any inline use.
const LINKEDIN_PATH = 'M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z';

// Single source of truth for the roster: cards and modals both render from this.
const groups = [
  {
    title: 'Management',
    layout: 'two',
    members: [
      {
        slug: 'chris-morin',
        name: 'Chris Morin',
        role: 'Founder',
        alt: 'Chris Morin, Founder of Moonraker',
        avif: '/assets/team/chris-morin.avif',
        img: '/assets/team/chris-morin.png',
        width: 1080,
        height: 1439,
        loading: 'eager',
        linkedin: 'https://www.linkedin.com/in/cjmorin/',
        bio: "Before marketing, I was a massage therapist for over 15 years, providing chair massage to local businesses. That work connected me to countless wellness providers and I had the opportunity to experience firsthand their deep desire to be of service in a world that desperately needs healing. I also witnessed how so many amazing practitioners struggle to connect with the clients who need their services the most. A highly intuitive group, many feel that digital marketing is overwhelming, causing them to avoid the necessary steps to establish an online presence. My goal is to help therapists and wellness providers boost their online visibility and connect with their ideal clients so they can build the practice of their dreams. I encourage you to check out our free resources, and don't hesitate to book a call as I would love to speak with you!",
      },
      {
        slug: 'scott-pope',
        name: 'Scott Pope',
        role: 'Director of Growth and Operations',
        alt: 'Scott Pope, Director of Growth and Operations at Moonraker',
        avif: '/assets/team/scott-pope.avif',
        img: '/assets/team/scott-pope.jpg',
        width: 1996,
        height: 1789,
        loading: 'eager',
        linkedin: 'https://www.linkedin.com/in/scott-pope-607888386/',
        bio: "At Moonraker, I lead our partnerships with educators, tech companies, and thought leaders across the therapy space. My work sits at the intersection of SEO strategy, AI adoption, and compliance, three areas that overwhelm most practitioners but determine whether their practices grow or stagnate. I write Moonraker's weekly newsletter, translating Google algorithm updates, AI developments, and compliance changes into plain English for busy clinicians. No jargon, just what matters and what to do about it. I manage our affiliate program and contribute to Engage, a HIPAA-compliant AI chatbot we are building specifically for therapy websites. I am currently building Thrive Summit 2026, a virtual event bringing 500+ therapists together with cybersecurity experts, practice consultants, and technology partners.",
      },
    ],
  },
  {
    title: 'SEO Team',
    layout: 'three',
    members: [
      {
        slug: 'ivhan-butalid',
        name: 'Ivhan Alhen Butalid',
        role: 'SEO Technician',
        alt: 'Ivhan Alhen Butalid, SEO Technician at Moonraker',
        avif: '/assets/team/ivhan-butalid.avif',
        img: '/assets/team/ivhan-butalid.jpeg',
        width: 1024,
        height: 1024,
        loading: 'lazy',
        linkedin: 'https://www.linkedin.com/in/ivhan-alhen-butalid-89294523b/',
        bio: 'My role is to implement the full CORE Marketing System for our clients, transforming invisible websites into local leaders. From initial strategic alignment to the final technical details, my goal is to ensure every pillar of your online presence is rock-solid. I help build the digital footprint your practice needs through entity grounding, social mesh, citations and schema architecture. I craft comprehensive specialty pages and localized content that teach Google exactly why your practice is the best choice in the area. My goal is to bridge the gap between complex technical specifications and your clinical expertise to turn prospects into clients.',
      },
      {
        slug: 'kael-penales',
        name: 'Kael Marie Penales',
        role: 'SEO Technician',
        alt: 'Kael Marie Penales, SEO Technician at Moonraker',
        avif: '/assets/team/kael-penales.avif',
        img: '/assets/team/kael-penales.jpeg',
        width: 450,
        height: 806,
        loading: 'lazy',
        linkedin: 'https://www.linkedin.com/in/kael-marie-penales-594653243/',
        bio: 'I work with our clients through the full SEO lifecycle, enhancing your clinical authority by optimizing your website to ensure it reflects your unique voice while meeting our rigorous SEO standards. I help our clients become the most prominent recommendation in AI search and Google Maps through a combination of speed, security and conversion rate optimizations and mobile-first design. I help to amplify your online reputation by leveraging your professional endorsements to more effectively demonstrate leadership in your field. What I enjoy most is the blend of creative and analytical work, crafting content that resonates while digging into the technical details that drive search performance.',
      },
      {
        slug: 'karen-francisco',
        name: 'Karen Francisco',
        role: 'Client Success Manager',

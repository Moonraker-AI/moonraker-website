---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Book a free strategy call - Moonraker" description="Book a free 30-minute strategy call with Scott Pope at Moonraker. We help therapy practices understand how they currently show up on Google, Maps, ChatGPT, Gemini, and AI tools." canonical="https://moonraker.ai/free-strategy-call" ogTitle="Book a free strategy call - Moonraker" ogDescription="A clear first call for therapy practices that shows whether Moonraker can help and where the biggest gaps are." ogUrl="https://moonraker.ai/free-strategy-call">
<main>

<div class="contact-wrap">
  <div class="contact-hero">
    <div class="contact-header">
      <h1>Book a free <span>strategy call.</span></h1>
      <p>A focused 30 minute call with Scott Pope, our Director of Growth and Operations. We will look at how your practice currently shows up across Google, Maps, ChatGPT, Gemini, and other AI tools.</p>
    </div>
    <div class="contact-video">
      <iframe src="https://www.loom.com/embed/df3a5aa47f284ade81a4649695ac42dd" loading="lazy" allow="fullscreen" allowfullscreen title="What a free strategy call with Moonraker looks like"></iframe>
    </div>
  </div>
</div>

<div id="bookingWorkspace" class="booking-workspace">
  <div class="tz-banner">
    <span class="tz-banner-icon">&#127758;</span>
    <div>
      <div><strong>Scott is based in Adelaide, Australia</strong> and takes new client calls Tuesday through Thursday, 9 AM to 5 PM local time.</div>
      <div class="tz-banner-line tz-zone-line">All times below are shown in your local zone (<span id="tzLabel">detecting...</span>).</div>
      <div class="tz-banner-line">Wrong zone? <select id="tzPicker" aria-label="Time zone"></select></div>
    </div>
  </div>
  <div class="booking-card">

    <!-- Step 1: pick date -->
    <div class="booking-step" id="step1" data-active="true">
      <h2>Pick a day</h2>
      <p class="helper">Available days are when Scott has open time over the next three weeks.</p>
      <div id="dateStrip" class="date-strip">
        <div class="loading-state">Loading availability...</div>
      </div>
    </div>

    <!-- Step 2: pick time -->
    <div class="booking-step" id="step2" hidden>
      <button type="button" class="step-back" onclick="goToStep(1)">Back to dates</button>
      <h2 id="step2Title">Pick a time</h2>
      <p class="helper" id="step2Helper">Each call is 30 minutes. We will email you a confirmation with the Zoom link.</p>
      <div id="timeGrid" class="time-grid"></div>
    </div>

    <!-- Step 3: form -->
    <div class="booking-step" id="step3" hidden>
      <button type="button" class="step-back" onclick="goToStep(2)">Back to times</button>
      <h2>A few details</h2>
      <p class="helper">Helps Scott prepare so the call can focus on what is working, what is missing, and whether Moonraker is a fit.</p>

      <div class="summary-box">
        <div class="summary-when" id="summaryWhen"></div>
        <div class="summary-sub" id="summarySub"></div>
      </div>

      <div class="form-grid">
        <div class="form-row">
          <label for="firstName">First name <span class="req">*</span></label>
          <input id="firstName" type="text" autocomplete="given-name" required>
          <div class="err">Please enter your first name.</div>
        </div>
        <div class="form-row">
          <label for="lastName">Last name <span class="req">*</span></label>
          <input id="lastName" type="text" autocomplete="family-name" required>
          <div class="err">Please enter your last name.</div>
        </div>
        <div class="form-row">
          <label for="email">Email <span class="req">*</span></label>
          <input id="email" type="email" autocomplete="email" required>
          <div class="err">Please enter a valid email address.</div>
        </div>
        <div class="form-row">
          <label for="phone">Phone <span class="req">*</span></label>
          <input id="phone" type="tel" autocomplete="tel" required>
          <div class="err">Please enter a phone number.</div>
        </div>
        <div class="form-row">
          <label for="practiceName">Practice name <span class="req">*</span></label>
          <input id="practiceName" type="text" autocomplete="organization" required>
          <div class="err">Please enter your practice name.</div>
        </div>
        <div class="form-row">
          <label for="websiteUrl">Practice website <span class="req">*</span></label>
          <input id="websiteUrl" type="url" placeholder="https://yourpractice.com" autocomplete="url" required>
          <div class="err">Please enter a valid website URL starting with https://.</div>
        </div>
        <div class="form-row full">
          <label for="practiceAddress">Practice address <span class="req">*</span></label>
          <input id="practiceAddress" type="text" autocomplete="address-line1" placeholder="Street address" required>
          <div class="err">Please enter your practice street address.</div>
        </div>
        <div class="form-row full">
          <label for="practiceAddress2">Suite, floor, or unit (optional)</label>
          <input id="practiceAddress2" type="text" autocomplete="address-line2" placeholder="Suite 200">
        </div>
        <div class="form-row">
          <label for="practiceCity">City</label>
          <input id="practiceCity" type="text" autocomplete="address-level2">
        </div>
        <div class="form-row">
          <label for="practiceState">State or province</label>
          <input id="practiceState" type="text" autocomplete="address-level1">
        </div>
        <div class="form-row">
          <label for="postalCode">Postal code</label>
          <input id="postalCode" type="text" autocomplete="postal-code">
        </div>
        <div class="form-row">
          <label for="country">Country</label>
          <input id="country" type="text" autocomplete="country-name" placeholder="e.g. United States">
        </div>
        <div class="form-row">
          <label for="hasGbp">Do you have a Google Business Profile?</label>
          <select id="hasGbp">
            <option value="">Select...</option>
            <option value="yes">Yes</option>
            <option value="no">Not yet</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>
        <div class="form-row is-hidden" id="gbpLinkRow">
          <label for="gbpLink">Google Business Profile link</label>
          <input id="gbpLink" type="url" placeholder="https://maps.app.goo.gl/...">
        </div>
        <div class="form-row full">
          <label for="referralSource">How did you hear about Moonraker?</label>
          <input id="referralSource" type="text" placeholder="A colleague, podcast, search, etc.">
        </div>
        <div class="form-row full">
          <label for="notes">Anything you'd like Scott to know in advance?</label>
          <textarea id="notes" rows="3" placeholder="Optional"></textarea>
        </div>
      </div>

      <div class="submit-row">
        <button type="button" class="btn btn-ghost" onclick="goToStep(2)">Back</button>
        <button type="button" class="btn btn-primary" id="submitBtn" onclick="submitBooking()">Confirm booking</button>
      </div>
      <div id="formError" class="error-state is-hidden"></div>
    </div>

    <!-- Step 4: confirmation -->
    <div class="booking-step confirm" id="step4" hidden>
      <div class="confirm-icon">&#10003;</div>
      <h2>You're booked.</h2>
      <p>A confirmation email is on its way with the Zoom link and a calendar invite. Scott will see you at your selected time.</p>
      <div class="confirm-details" id="confirmDetails"></div>
      <p class="confirm-note">Need to change anything? Reply to the confirmation email and we will sort it.</p>
    </div>

  </div>
</div>

<section class="reviews-section">
  <div class="reviews-head">
    <div class="eyebrow">Reviews</div>
    <h2>Loved by practices like yours</h2>
    <p>Verified Google reviews from the therapists and practice owners we work with. Your free strategy call is the first step.</p>
  </div>

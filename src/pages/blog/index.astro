---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPieces, TYPE_LABELS, formatDate } from '../../lib/content.js';

const pieces = await getPublishedPieces();

const title = 'Blog | Moonraker';
const description =
  'Field notes, case reports, and guides on AI search visibility and entity SEO for therapy practices.';
const canonical = 'https://moonraker.ai/blog';

const itemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: pieces.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `https://moonraker.ai/blog/${p.slug}`,
    name: p.title,
  })),
};
---
<BaseLayout title={title} description={description} canonical={canonical} ogUrl={canonical}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(itemList)} />

  <section class="blog-hero">
    <div class="blog-hero-inner">
      <div class="hero-kicker">Blog</div>
      <h1>Field notes on AI search visibility</h1>
      <p>Case reports, guides, and what we learn building entity presence for therapy practices.</p>
    </div>
  </section>

  <section class="blog-wrap">
    {pieces.length === 0 ? (
      <p class="blog-empty">New writing is on the way. Check back soon.</p>
    ) : (
      <div class="blog-grid">
        {pieces.map((p) => (
          <article class="blog-card">
            <a href={`/blog/${p.slug}`} class="blog-card-link" aria-label={p.title}></a>
            <div class="blog-card-meta">
              <span class="blog-badge">{TYPE_LABELS[p.type] || p.type}</span>
              {p.published_at && <time datetime={p.published_at}>{formatDate(p.published_at)}</time>}
            </div>
            <h2 class="blog-card-title">{p.title}</h2>
            {p.excerpt && <p class="blog-card-excerpt">{p.excerpt}</p>}
            <span class="blog-card-cta">Read more &rarr;</span>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .blog-hero { padding: 5rem 1.5rem 2.5rem; text-align: center; }
  .blog-hero-inner { max-width: 760px; margin: 0 auto; }
  .hero-kicker {
    display: inline-block; font-weight: 600; font-size: 0.8rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--color-primary); margin-bottom: 0.75rem;
  }
  .blog-hero h1 { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.1; margin: 0 0 0.75rem; }
  .blog-hero p { font-size: 1.125rem; color: var(--color-muted); margin: 0; }

  .blog-wrap { max-width: 1080px; margin: 0 auto; padding: 1rem 1.5rem 6rem; }
  .blog-empty { text-align: center; color: var(--color-muted); padding: 3rem 0; }

  .blog-grid {
    display: grid; gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }
  .blog-card {
    position: relative; display: flex; flex-direction: column;
    border: 1px solid var(--color-border); border-radius: 16px;
    padding: 1.5rem; background: var(--color-surface);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  .blog-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
    border-color: var(--color-primary);
  }
  .blog-card-link { position: absolute; inset: 0; z-index: 1; }
  .blog-card-meta {
    display: flex; align-items: center; gap: 0.75rem;
    font-size: 0.8rem; color: var(--color-muted); margin-bottom: 0.75rem;
  }
  .blog-badge {
    font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
    color: var(--color-primary); font-size: 0.72rem;
  }
  .blog-card-title { font-size: 1.3rem; line-height: 1.25; margin: 0 0 0.5rem; }
  .blog-card-excerpt { color: var(--color-muted); margin: 0 0 1rem; flex: 1; }
  .blog-card-cta { font-weight: 600; color: var(--color-primary); font-size: 0.95rem; }
</style>

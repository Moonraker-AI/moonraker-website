---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPieces, getPieceBySlug, TYPE_LABELS, formatDate } from '../../lib/content.js';

export async function getStaticPaths() {
  const pieces = await getPublishedPieces();
  return pieces.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const piece = await getPieceBySlug(slug);
if (!piece) return Astro.redirect('/blog');

const seo = piece.seo || {};
const canonical = `https://moonraker.ai/blog/${piece.slug}`;
const description = seo.meta_description || piece.excerpt || '';
const ogImage = seo.og_image || undefined;
const keywords = Array.isArray(seo.keywords) ? seo.keywords.filter(Boolean) : [];

// Render the markdown, then make external links open safely in a new tab. Links
// to moonraker.ai stay as internal same-tab links (no rel change).
let bodyHtml = piece.body_md ? marked.parse(piece.body_md) : '';
// Drop a leading H1: the page already renders the title in .post-head, and AI
// drafts routinely repeat it as the first line of the body. Keeps a single H1.
bodyHtml = bodyHtml.replace(/^\s*<h1[^>]*>[\s\S]*?<\/h1>\s*/i, '');
bodyHtml = bodyHtml.replace(/<a href="(https?:\/\/[^"]+)"/g, (m, href) =>
  /^https?:\/\/(www\.)?moonraker\.ai(\/|$)/i.test(href) ? m : `<a href="${href}" target="_blank" rel="noopener"`
);
const wordCount = piece.body_md
  ? piece.body_md.replace(/[#*_`>\[\]()!-]/g, ' ').split(/\s+/).filter(Boolean).length
  : undefined;
const metrics = piece.metrics && typeof piece.metrics === 'object' ? Object.entries(piece.metrics) : [];

// Author: named persona for a human E-E-A-T signal. sameAs points at the public
// profiles linked from the team bio page.
const AUTHOR = {
  '@type': 'Person',
  name: 'Chris Morin',
  jobTitle: 'Founder',
  url: 'https://moonraker.ai/team',
  image: 'https://moonraker.ai/assets/team/chris-morin.png',
  sameAs: ['https://www.linkedin.com/in/cjmorin/'],
  worksFor: { '@type': 'Organization', name: 'Moonraker AI', url: 'https://moonraker.ai' },
};

// Related posts: other published pieces, same type first, newest first, max 3.
const allPieces = await getPublishedPieces();
const others = allPieces.filter((p) => p.slug !== piece.slug);
const related = others
  .filter((p) => p.type === piece.type)
  .concat(others.filter((p) => p.type !== piece.type))
  .slice(0, 3);

// Structured data: BlogPosting + Breadcrumb (+ FAQPage when the piece carries FAQs).
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: piece.title,
  description,
  datePublished: piece.published_at,
  ...(piece.updated_at ? { dateModified: piece.updated_at } : {}),
  author: AUTHOR,
  publisher: {
    '@type': 'Organization',
    name: 'Moonraker AI',
    logo: { '@type': 'ImageObject', url: 'https://moonraker.ai/assets/logo.png' },
  },
  mainEntityOfPage: canonical,
  inLanguage: 'en-US',
  ...(keywords.length ? { keywords: keywords.join(', ') } : {}),
  ...(wordCount ? { wordCount } : {}),
  ...(piece.type ? { articleSection: TYPE_LABELS[piece.type] || piece.type } : {}),
  image: ogImage || 'https://moonraker.ai/assets/logo.png',
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Blog', item: 'https://moonraker.ai/blog' },
    { '@type': 'ListItem', position: 2, name: piece.title, item: canonical },
  ],
};
const faqs = Array.isArray(seo.faq) ? seo.faq.filter((f) => f && f.q && f.a) : [];
const faqLd = faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---
<BaseLayout
  title={`${piece.title} | Moonraker`}
  description={description}
  canonical={canonical}
  ogUrl={canonical}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <article class="post">
    <header class="post-head">
      <nav class="post-crumbs"><a href="/blog">Blog</a> <span>/</span> {TYPE_LABELS[piece.type] || piece.type}</nav>
      <h1>{piece.title}</h1>
      <p class="post-byline">
        By <a href="/team">Chris Morin</a>, Founder
        {piece.published_at && <> <span aria-hidden="true">&middot;</span> <time datetime={piece.published_at}>{formatDate(piece.published_at)}</time></>}
      </p>
      {piece.excerpt && <p class="post-lede">{piece.excerpt}</p>}
    </header>

    {metrics.length > 0 && (
      <ul class="post-metrics">
        {metrics.map(([k, v]) => (
          <li><strong>{String(v)}</strong><span>{k.replace(/_/g, ' ')}</span></li>
        ))}
      </ul>
    )}

    <div class="post-body" set:html={bodyHtml}></div>

    {faqs.length > 0 && (
      <section class="post-faq">
        <h2>Frequently asked questions</h2>
        <div class="faq-accordion" data-faq-accordion>
          {faqs.map((f, i) => (
            <div class="faq-item">
              <button class="faq-trigger" type="button" aria-expanded="false" aria-controls={`faq-a-${i}`} data-faq-trigger>
                <span class="faq-q">{f.q}</span>
                <span class="faq-icon" aria-hidden="true">+</span>
              </button>
              <div id={`faq-a-${i}`} class="faq-answer-wrap">
                <div class="faq-answer"><p>{f.a}</p></div>
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="post-related">
        <h2>Related reading</h2>
        <ul>
          {related.map((p) => (
            <li>
              <a href={`/blog/${p.slug}`}>{p.title}</a>
              <span class="post-related-type">{TYPE_LABELS[p.type] || p.type}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="post-cta">
      <h2>Want this for your practice?</h2>
      <p>See whether Moonraker can close the gaps in your search and AI visibility.</p>
      <a href="/free-strategy-call" class="post-cta-btn">Book a free strategy call</a>
    </footer>
  </article>
</BaseLayout>

<style>
  /* Match the site container width so the article aligns with the nav. The
     running prose stays at a readable measure and left-aligns to the title;
     the metrics / FAQ / related / CTA blocks span the full width. */
  .post { width: min(1120px, calc(100% - 3rem)); margin: 0 auto; padding: 4rem 0 5rem; }
  .post-head, .post-body { max-width: 760px; }
  .post-head { margin-bottom: 2.5rem; }
  .post-crumbs { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 1rem; }
  .post-crumbs a { color: var(--color-primary); text-decoration: none; }
  .post-crumbs span { margin: 0 0.4rem; }
  .post-head h1 { font-size: clamp(1.9rem, 4.5vw, 2.75rem); line-height: 1.12; margin: 0 0 0.75rem; }
  .post-byline { color: var(--color-muted); font-size: 0.9rem; margin: 0 0 1rem; }
  .post-byline a { color: var(--color-primary); text-decoration: none; font-weight: 600; }
  .post-byline time { font-variant-numeric: tabular-nums; }
  .post-lede { font-size: 1.2rem; line-height: 1.5; color: var(--color-muted); margin: 0; }

  .post-related { margin: 3.5rem 0 0; }
  .post-related h2 { font-size: 1.5rem; margin: 0 0 1.25rem; }
  .post-related ul { list-style: none; padding: 0; margin: 0; }
  .post-related li {
    display: flex; align-items: baseline; justify-content: space-between; gap: 1rem;
    padding: 0.85rem 0; border-bottom: 1px solid var(--color-border);
  }
  .post-related a { color: var(--color-primary); text-decoration: none; font-weight: 600; }
  .post-related a:hover { text-decoration: underline; }
  .post-related-type {
    flex-shrink: 0; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em;
    color: var(--color-muted);
  }

  .post-metrics {
    list-style: none; display: flex; flex-wrap: wrap; gap: 1.5rem;
    padding: 1.25rem 1.5rem; margin: 0 0 2.5rem;
    border: 1px solid var(--color-border); border-radius: 14px; background: var(--color-surface);
  }
  .post-metrics li { display: flex; flex-direction: column; }
  .post-metrics strong { font-size: 1.6rem; color: var(--color-primary); line-height: 1; }
  .post-metrics span { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-muted); margin-top: 0.35rem; }

  .post-body { font-size: 1.075rem; line-height: 1.75; }
  .post-body :global(h2) { font-size: 1.6rem; margin: 2.5rem 0 1rem; line-height: 1.2; }
  .post-body :global(h3) { font-size: 1.25rem; margin: 2rem 0 0.75rem; }
  .post-body :global(p) { margin: 0 0 1.25rem; }
  .post-body :global(ul), .post-body :global(ol) { margin: 0 0 1.25rem; padding-left: 1.4rem; }
  .post-body :global(li) { margin: 0 0 0.5rem; }
  .post-body :global(a) { color: var(--color-primary); }
  .post-body :global(blockquote) {
    margin: 1.5rem 0; padding: 0.5rem 1.25rem; border-left: 3px solid var(--color-primary);
    color: var(--color-muted); font-style: italic;
  }
  .post-body :global(img) { max-width: 100%; height: auto; border-radius: 12px; }
  .post-body :global(code) {
    background: var(--color-surface); padding: 0.15em 0.4em; border-radius: 6px; font-size: 0.9em;
  }

  .post-faq { margin: 3.5rem 0 0; }
  .post-faq h2 { font-size: 1.5rem; margin: 0 0 1.25rem; }
  /* Accordion: single-open, smooth grid-row reveal, padded rows (mirrors the
     named-template FaqBlock accordion variant). Behaviour script below. */
  .faq-accordion { display: grid; }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item:first-child { border-top: 1px solid var(--color-border); }
  .faq-trigger {
    width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1.25rem;
    padding: 1.25rem 0.25rem; background: transparent; border: 0; text-align: left; cursor: pointer;
    color: var(--color-heading, inherit); font: inherit; transition: color 200ms ease;
  }
  .faq-trigger:hover { color: var(--color-primary); }
  .faq-trigger:focus-visible { outline: 2px solid var(--color-primary); outline-offset: 3px; border-radius: 6px; }
  .faq-q { font-size: 1.075rem; font-weight: 700; line-height: 1.35; }
  .faq-icon {
    flex-shrink: 0; font-size: 1.6rem; line-height: 1; color: var(--color-primary);
    transition: transform 320ms cubic-bezier(0.16, 1, 0.3, 1); transform-origin: center;
  }
  .faq-trigger[aria-expanded="true"] .faq-icon { transform: rotate(45deg); }
  .faq-answer-wrap {
    display: grid; grid-template-rows: 0fr;
    transition: grid-template-rows 360ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .faq-trigger[aria-expanded="true"] + .faq-answer-wrap { grid-template-rows: 1fr; }
  .faq-answer { min-height: 0; overflow: hidden; }
  .faq-answer p { margin: 0; padding: 0 0.25rem 1.4rem; color: var(--color-muted); line-height: 1.7; max-width: 760px; }

  .post-cta {
    margin: 4rem 0 0; padding: 2.5rem; text-align: center;
    border: 1px solid var(--color-border); border-radius: 18px; background: var(--color-surface);
  }
  .post-cta h2 { font-size: 1.6rem; margin: 0 0 0.5rem; }
  .post-cta p { color: var(--color-muted); margin: 0 0 1.5rem; }
  .post-cta-btn {
    display: inline-block; background: var(--color-primary); color: #fff;
    padding: 0.85rem 1.75rem; border-radius: 10px; font-weight: 600; text-decoration: none;
  }
</style>

<script is:inline>
  // FAQ accordion: single-open, and on open scroll the question to just below
  // the sticky nav (waiting for the grid-row reveal to settle). Mirrors the
  // named-template FaqAccordionScript so the behaviour matches the client sites.
  (() => {
    function initFaq() {
      document.querySelectorAll('[data-faq-accordion]').forEach((group) => {
        if (group.dataset.faqReady === 'true') return;
        group.dataset.faqReady = 'true';
        const triggers = Array.from(group.querySelectorAll('[data-faq-trigger]'));
        triggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const expanded = trigger.getAttribute('aria-expanded') === 'true';
            triggers.forEach((other) => { if (other !== trigger) other.setAttribute('aria-expanded', 'false'); });
            const willOpen = !expanded;
            trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
            if (willOpen) {
              setTimeout(() => {
                const nav = document.querySelector('.site-nav');
                const navH = nav ? nav.getBoundingClientRect().height : 0;
                const rect = trigger.getBoundingClientRect();
                const minY = navH + 16;
                const maxY = window.innerHeight - 120;
                if (rect.top < minY || rect.top > maxY) {
                  window.scrollTo({ top: Math.max(window.scrollY + rect.top - minY, 0), behavior: 'smooth' });
                }
              }, 380);
            }
          });
        });
      });
    }
    initFaq();
    document.addEventListener('DOMContentLoaded', initFaq);
  })();
</script>
